{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "enabled_providers": ["anthropic", "openai"],

  "model": "anthropic/claude-opus-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",

  "permission": {
    "read": {
      ".trees/*": "deny",
      "research/*": "deny",
      "node_modules/*": "deny",
    },
  },

  "agent": {
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
    },
  },

  // "server": {
  //   "hostname": "0.0.0.0",
  //   "port": 4096,
  // },
}
